# Public-data API keys — copy to .env and fill in.
# See documentation/API_Pricing.md for full pricing/tier details.

# FRED (Federal Reserve) — free, required for real macro data in Macro.ipynb / btc.ipynb
# https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_key_here

# CoinGecko — free Demo key for stable rate limit in ccquant sync universe
# https://www.coingecko.com/en/api/pricing
CG_DEMO_API_KEY=your_coingecko_demo_key_here

# bitcoinisdata.com — paid (~25k sats/yr, BTC/Lightning), real MVRV/NUPL/realized_price
# https://bitcoinisdata.com/accounts/buy_subscription/
BITCOIN_IS_DATA_KEY=your_bid_key_here

# bitcoinisdata.com — path to downloaded full CSV (alternative to API key)
# BID_CSV_PATH=data/bitcoinisdata_full.csv

# Glassnode — paid Professional tier ($799+/mo) + Data Credits, SOPR/RHODL/exchange balance
# https://studio.glassnode.com/pricing
# GLASSNODE_API_KEY=your_glassnode_key_here

# CryptoQuant — paid ($29+/mo), exchange flows (future v2 integration)
# https://cryptoquant.com/pricing
# CRYPTOQUANT_API_KEY=your_cryptoquant_key_here

# Wallet intelligence — free tiers
# Flipside: https://flipsidecrypto.xyz/settings/api
# FLIPSIDE_API_KEY=your_flipside_key_here
# Etherscan: https://etherscan.io/apis (Arbitrum via Arbiscan key optional)
# ETHERSCAN_API_KEY=your_etherscan_key_here
# Telegram alerts (optional): create via BotFather
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# TELEGRAM_CHAT_ID=your_chat_id_here

# Twitter / X — Phase 2+ live tail only (v1 uses CSV/JSONL import, $0)
# https://developer.x.com
# X_API_BEARER_TOKEN=your_x_bearer_token_here

# Override DuckDB paths (optional)
# CCQUANT_DB=data/ccquant.duckdb
# CCQUANT_ONCHAIN_DB=data/onchain.duckdb
